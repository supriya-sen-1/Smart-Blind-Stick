# ----------------------------------------------------------
# PlatformIO
# ----------------------------------------------------------
.pio/
.piolibdeps/

# ----------------------------------------------------------
# VS Code
# ----------------------------------------------------------
.vscode/.browse.c_cpp.db*
.vscode/ipch/
.vscode/*.log

# Uncomment if you don't want to share your VS Code settings
# .vscode/settings.json

# ----------------------------------------------------------
# Build Files
# ----------------------------------------------------------
*.o
*.obj
*.elf
*.bin
*.hex
*.map

# ----------------------------------------------------------
# C/C++
# ----------------------------------------------------------
*.d
*.gcda
*.gcno
*.gcov

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ----------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# Linux
*~

# ----------------------------------------------------------
# IDE Files
# ----------------------------------------------------------
.idea/
*.code-workspace

# ----------------------------------------------------------
# Upload/Test Files (Optional)
# ----------------------------------------------------------
test/output/
test/build/

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.zip
*.7z
*.rar
*.tar
*.gz